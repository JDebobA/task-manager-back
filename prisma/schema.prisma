// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Модель юзера
model User {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  email          String           @unique
  name           String?
  password       String
  breakInterval  Int              @default(5) @map("break_interval")
  intervalsCount Int              @default(3) @map("interval_count")
  workInteval    Int              @default(30) @map("work_inteval")
  task           Task[]
  session        PromodoSession[]
  timeBlock      Timeblock[]
}

//Модель задач
model Task {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  name       String?
  isComleted Boolean  @map("is_completed")
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  priority   Priority
}

enum Priority {
  Priority
}

//Модель сессии
model PromodoSession {
  id          String         @id @default(uuid())
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  isComplited Boolean        @map("is_complited")
  user        User?          @relation(fields: [userId], references: [id])
  userId      String?        @map("user_id")
  rounds      PromodoRound[]
}

//Модель Раунда
model PromodoRound {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  allMinutes       Int            @map("all_minutes")
  completed        Boolean
  promodoSessionId String         @map("promodo_session_id")
  promodoSession   PromodoSession @relation(fields: [promodoSessionId], references: [id])
}

//Модель временного блока
model Timeblock {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  name      String
  color     String   @default("#a03a3a")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
